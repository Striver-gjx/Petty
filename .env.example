# ============================================================
# Petty - 宠物上门喂养服务平台 环境变量配置模板
# 复制本文件为 .env 并填入实际值
# ============================================================

# ---- 应用配置 ----
APP_PORT=18080
APP_ENV=dev

# ---- 数据库 (MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=petty
DB_USER=petty
DB_PASS=petty123

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- RabbitMQ (消息队列) ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=petty
RABBITMQ_PASS=petty123

# ---- 阿里云 OSS (文件存储) ----
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_BUCKET=petty-media

# ---- 微信小程序 ----
WECHAT_APPID=your_appid
WECHAT_SECRET=your_secret

# ---- 微信支付 ----
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_KEY=your_api_key
WECHAT_PAY_CERT_PATH=/path/to/apiclient_cert.p12
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/payments/notify

# ---- JWT 认证 ----
JWT_SECRET=your_jwt_secret_key_at_least_32_chars
JWT_EXPIRE_HOURS=168

# ---- 高德地图 API ----
AMAP_KEY=your_amap_web_service_key

# ---- 管理后台 ----
ADMIN_WEB_PORT=3000
